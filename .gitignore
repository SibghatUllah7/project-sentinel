# Project Sentinel .gitignore

# Certificates and keys — NEVER commit these
*.pem
*.key
*.crt
*.p12
*.pfx
certs/
certificates/

# Wazuh config with passwords
internal_users.yml
wazuh.yml

# Docker sensitive files
.env
docker-compose.override.yml

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor files
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
logs/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Screenshots with sensitive info
# Add your own exclusions below
