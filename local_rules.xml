  sudo docker cp local_rules.xml single-node-wazuh.manager-1:/var/ossec/etc/rules/local_rules.xml
  sudo docker exec single-node-wazuh.manager-1 /var/ossec/bin/wazuh-control restart
-->

<!-- ════════════════════════════════════════════════════
     SSH BRUTE FORCE DETECTION
     MITRE ATT&CK: T1110 — Brute Force
     ════════════════════════════════════════════════════ -->
<group name="sentinel,authentication_failed,">

  <!-- Level 5: Multiple SSH authentication failures from same IP -->
  <rule id="100001" level="5">
    <if_matched_sid>5716</if_matched_sid>
    <same_source_ip />
    <description>Sentinel: Multiple SSH authentication failures from same IP</description>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>

  <!-- Level 10: SSH Brute Force — 8+ failures in 2 minutes -->
  <rule id="100002" level="10" frequency="8" timeframe="120">
    <if_matched_sid>100001</if_matched_sid>
    <same_source_ip />
    <description>Sentinel: SSH Brute Force attack detected - 8+ failures in 2 minutes from same IP</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
  </rule>

</group>

<!-- ════════════════════════════════════════════════════
     PORT SCAN DETECTION
     MITRE ATT&CK: T1046 — Network Service Discovery
     ════════════════════════════════════════════════════ -->
<group name="sentinel,recon,">

  <!-- Level 8: Port scan detected -->
  <rule id="100003" level="8">
    <if_sid>40101</if_sid>
    <description>Sentinel: Port scan detected from source IP — possible reconnaissance activity</description>
    <mitre>
      <id>T1046</id>
    </mitre>
  </rule>

</group>

<!-- ════════════════════════════════════════════════════
     PRIVILEGE ESCALATION DETECTION
     MITRE ATT&CK: T1548.003 — Sudo and Sudo Caching
     ════════════════════════════════════════════════════ -->
<group name="sentinel,privilege_escalation,">

  <!-- Level 12: Possible privilege escalation via sudo -->
  <rule id="100004" level="12">
    <if_sid>5402</if_sid>
    <description>Sentinel: Possible privilege escalation detected - sudo misuse or SUID exploitation</description>
    <mitre>
      <id>T1548.003</id>
    </mitre>
  </rule>

</group>

<!-- ════════════════════════════════════════════════════
     NEW USER ACCOUNT CREATION
     MITRE ATT&CK: T1136 — Create Account
     ════════════════════════════════════════════════════ -->
<group name="sentinel,persistence,">

  <!-- Level 8: New user account created -->
  <rule id="100005" level="8">
    <if_sid>5901</if_sid>
    <description>Sentinel: New user account created — possible persistence mechanism</description>
    <mitre>
      <id>T1136.001</id>
    </mitre>
  </rule>

</group>

<!-- ════════════════════════════════════════════════════
     LOG TAMPERING DETECTION
     MITRE ATT&CK: T1070 — Indicator Removal
     ════════════════════════════════════════════════════ -->
<group name="sentinel,defense_evasion,">

  <!-- Level 10: Log file deleted or tampered -->
  <rule id="100006" level="10">
    <if_sid>591</if_sid>
    <match>deleted</match>
    <description>Sentinel: Log file deletion detected — possible evidence tampering</description>
    <mitre>
      <id>T1070.002</id>
    </mitre>
  </rule>

</group>
